{
  "dataSources": {
    "ds_vSsjeRvP": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.session.connect\" | timechart span=4h count BY dst_ip limit=0",
        "queryParameters": {
          "earliest": "$global_time.earliest$",
          "latest": "$global_time.latest$"
        }
      },
      "name": "Dest IP usage search"
    },
    "ds_I9HdNZbY": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.session.connect\"\n| stats count AS cps BY _time session dst_ip\n| timechart span=1h sum(cps) BY dst_ip",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Connections per destination search"
    },
    "ds_wC3kYqjK": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.session.connect\"\n| stats count as connection_count by src_ip\n| ipinfolite src_ip\n| stats sum(connection_count) as connection_sum count(src_ip) as ip_count by asn as_name\n| sort -ip_count",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Top ASN_s search"
    },
    "ds_bXP2HV0G": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"\n| stats count AS cps BY _time session sensor\n| timechart span=1h sum(cps) BY sensor",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Sensor events search"
    },
    "ds_wih9JCQ2": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.command.input\"\n| stats count AS cps BY _time sensor session\n| timechart span=1h avg(cps) BY sensor",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Commands per session over time search"
    },
    "ds_Sz9YxAzN": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.command.input\" | top limit=50 input",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Top commands executed search"
    },
    "ds_WRscJ7bc": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" \n| spath eventid \n| search eventid=\"cowrie.login.success\"\n| top limit=10 password\n| fields - percent",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Top Passwords search"
    },
    "ds_0w5O7Lrx": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" \n| spath eventid \n| search eventid=\"cowrie.login.success\"\n| top limit=10 username\n| fields - percent",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Top Usernames search"
    },
    "ds_9UD8v0YC": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" \n| spath eventid \n| search eventid=\"cowrie.login.success\" \n| eval credentials = username + \" / \" + password \n| top limit=15 credentials\n| fields - percent",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Bar chart search"
    },
    "ds_6loAQPDp": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" | spath eventid | search eventid=\"cowrie.session.connect\" | spath src_ip | iplocation src_ip | geostats latfield=lat, longfield=lon count",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Attacker by destination search"
    },
    "ds_l3MRIwqh": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" | spath eventid | search eventid=\"cowrie.session.connect\" | stats count(dst_ip) as count by dst_ip",
        "queryParameters": {
          "sampleRatio": 1
        }
      },
      "name": "Destinations search"
    },
    "ds_OUyhxNYZ": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" | spath eventid | search eventid=\"cowrie.session.connect\" | spath src_ip | iplocation src_ip | stats count by Country| geom geo_countries allFeatures=True featureIdField=Country"
      },
      "name": "Search_1"
    },
    "ds_pXyBPylP": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"| top limit=1000 version"
      },
      "name": "Top SSH Client Versions"
    },
    "ds_fdkkx09i": {
      "type": "ds.search",
      "options": {
        "enableSmartSources": true,
        "query": "index=\"cowrie\" | stats dc(src_ip) as \"Unique Attacking IPs\""
      },
      "name": "total_unqiue_attackers_search"
    },
    "ds_nXfqfWNk": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.client.kex\"\n| stats count dc(src_ip) as \"Unique IPs Used\" by hassh\n| sort - \"Unique IPs Used\" \n|  head 35",
        "enableSmartSources": true
      },
      "name": "Unique IPs per HASSH"
    },
    "ds_ni110Qyk": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"\n[ search index=\"cowrie\" \n  | top limit=9 version \n  | fields version ]\n| chart count over version by sensor"
      },
      "name": "SSH types per sensor"
    },
    "ds_9Kpox1GR": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"\n| chart count over sensor by version limit=9 useother=t otherstr=\"Other\"\n| addtotals fieldname=TotalRows\n| foreach * [eval <<FIELD>> = if(\"<<FIELD>>\"==\"sensor\" OR \"<<FIELD>>\"==\"TotalRows\", <<FIELD>>, round(('<<FIELD>>' / TotalRows) * 100, 2) . \"%\")]\n| fields - TotalRows"
      },
      "name": "Types of connections per sensor"
    },
    "ds_UToaPpiI": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.login.success\" OR eventid=\"cowrie.command.input\"\n| stats count(eval(eventid=\"cowrie.command.input\")) as cmd_count by sensor, session\n| eval source = sensor\n| eval bucket = case(cmd_count == 0, \"Bounced\", cmd_count == 1, \"1 cmd\", cmd_count == 2, \"2 cmds\", cmd_count == 3, \"3 cmds\", true(), \"Deeply Engaged (4+ cmds)\")\n| eval target = sensor . \" -> \" . bucket\n| stats count as value by source, target"
      },
      "name": "Connection drop off after commands"
    },
    "ds_nlajiWUB": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.login.success\" OR eventid=\"cowrie.command.input\"\n| stats count(eval(eventid=\"cowrie.command.input\")) as cmd_count by sensor, session\n| eval Behavior = case(cmd_count == 0, \"Bounced\", cmd_count == 1, \"1 cmd\", cmd_count == 2, \"2 cmds\", cmd_count == 3, \"3 cmds\", true(), \"Deeply Engaged (4+ cmds)\")\n| chart count over sensor by Behavior\n| fields sensor, Bounced, \"1 cmd\", \"2 cmds\", \"3 cmds\", \"Deeply Engaged (4+ cmds)\""
      },
      "name": "Number of commands before drop"
    },
    "ds_tmN4dWwE": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.login.success\" OR eventid=\"cowrie.command.input\" OR eventid=\"cowrie.client.kex\"\n| stats count(eval(eventid=\"cowrie.command.input\")) as cmd_count, max(hassh) as hassh by sensor, session\n| search hassh=*\n| eval Behavior = case(cmd_count == 0, \"Bounced\", cmd_count == 1, \"1 cmd\", cmd_count == 2, \"2 cmds\", cmd_count == 3, \"3 cmds\", true(), \"Deeply Engaged (4+ cmds)\")\n| chart dc(hassh) over sensor by Behavior\n| fields sensor, Bounced, \"1 cmd\", \"2 cmds\", \"3 cmds\", \"Deeply Engaged (4+ cmds)\""
      },
      "name": "Unique hassh drop off after commands"
    },
    "ds_mwBa0vhm": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.command.input\"\n| sort 0 _time\n| stats list(input) as command_chain, count as total_cmds by sensor, session\n| where total_cmds > 1\n| eval command_chain = mvjoin(command_chain, \"  -->  \")\n| top limit=15 command_chain by sensor"
      },
      "name": "command chains"
    },
    "ds_TUEW1Qyz": {
      "type": "ds.search",
      "options": {
        "query": "index=cowrie eventid=\"cowrie.command.input\"\n| regex input=\"authorized_keys\"\n| rex field=input \"(?<ssh_key>ssh-\\w+\\s+[A-Za-z0-9+/=]+)\"\n| stats count as deploy_count dc(src_ip) as deploy_ip_count values(src_ip) as deploy_ips by ssh_key\n| join type=inner ssh_key [\n    search index=cowrie eventid=\"cowrie.client.fingerprint\"\n    | rename key as ssh_key\n    | stats count as auth_count dc(src_ip) as auth_ip_count values(src_ip) as auth_ips values(fingerprint) as fingerprint by ssh_key\n]\n| eval deploys_per_ip=round(deploy_count/deploy_ip_count,2)\n| eval auths_per_ip=round(auth_count/auth_ip_count,2)\n| eval first_five_deploy_ips=mvindex(deploy_ips, 0, 4)\n| table fingerprint deploy_count deploy_ip_count first_five_deploy_ips deploys_per_ip auth_count auth_ips auths_per_ip ssh_key\n| sort -deploy_count",
        "queryParameters": {
          "earliest": "0",
          "latest": ""
        }
      },
      "name": "Search_2"
    },
    "ds_TuE74ssp": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.command.input\"\n| regex input=\"authorized_keys\"\n| rex field=input \"(?<ssh_key>ssh-\\w+\\s+[A-Za-z0-9+/=]+)\"\n| stats count as deploy_count by ssh_key\n| join type=left ssh_key [\n    search index=\"cowrie\" eventid=\"cowrie.client.fingerprint\"\n    | rename key as ssh_key\n    | stats first(fingerprint) as fingerprint by ssh_key\n]\n| table fingerprint deploy_count ssh_key\n| sort -deploy_count",
        "queryParameters": {
          "earliest": "0",
          "latest": ""
        }
      },
      "name": "Search_3"
    },
    "ds_g8KKdByh": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" eventid=\"cowrie.client.fingerprint\"\n| rename key as ssh_key\n| stats count as auth_count\n        values(username) as usernames\n        first(fingerprint) as fingerprint\n        by ssh_key\n| table fingerprint auth_count usernames ssh_key\n| sort -auth_count",
        "queryParameters": {
          "earliest": "0",
          "latest": ""
        }
      },
      "name": "Search_4"
    },
    "ds_eHKxkJGW": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"\n| eval level=case(\n    eventid=\"cowrie.client.version\",1,\n    eventid=\"cowrie.client.kex\",2,\n    match(eventid,\"^cowrie\\.login\\.\"),3,\n    true(),0\n)\n| stats\n    max(level) as max_stage\n    first(sensor) as sensor\n    by session\n| eval banner=if(max_stage=1,1,0)\n| stats\n    count as total_sessions\n    sum(banner) as banner_sessions\n    by sensor\n| eval banner_pct=round((banner_sessions/total_sessions)*100,2)\n| table sensor total_sessions banner_sessions banner_pct"
      },
      "name": "Banner disconnects"
    },
    "ds_pOWllc2t": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"\n| eval level=case(\n    eventid=\"cowrie.client.version\",1,\n    eventid=\"cowrie.client.kex\",2,\n    match(eventid,\"^cowrie\\.login\\.\"),3,\n    true(),0\n)\n| stats\n    max(level) as max_stage\n    first(sensor) as sensor\n    by session\n| eval kex_only=if(max_stage=2,1,0)\n| stats\n    count as total_sessions\n    sum(kex_only) as kex_sessions\n    by sensor\n| eval kex_pct=round((kex_sessions/total_sessions)*100,2)\n| table sensor total_sessions kex_sessions kex_pct"
      },
      "name": "KEX disconnects"
    },
    "ds_8VTJFBNq": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" (eventid=\"cowrie.command.input\" OR eventid=\"cowrie.session.closed\")\n| eval config_group = case(\n    match(sensor, \"combined\"), \"Combined (Banner + Uname)\",\n    match(sensor, \"baseline\"), \"Baseline (Standard Cowrie)\"\n  )\n| stats \n    count as total_commands,\n    values(input) as all_commands,\n    dc(input) as distinct_session_cmds,\n    min(_time) as session_start,\n    max(_time) as session_end\n    by config_group, session\n| eval session_duration = session_end - session_start\n| eval contains_uname = if(match(all_commands, \"uname\"), 1, 0)\n| eval panic_exit = if(match(all_commands, \"(exit|logout|history\\s+-c|kill\\s+-9)\"), 1, 0)\n| where total_commands > 2 AND contains_uname=1\n| stats \n    count as qualification_sessions,\n    avg(distinct_session_cmds) as avg_unique_cmds,\n    max(distinct_session_cmds) as max_unique_cmds,\n    avg(session_duration) as avg_duration_seconds,\n    max(session_duration) as max_duration_seconds,\n    median(session_duration) as median_duration_seconds,\n    perc90(session_duration) as p90_duration_seconds,\n    perc95(session_duration) as p95_duration_seconds,\n    sum(panic_exit) as total_panic_exits\n    by config_group\n| eval panic_rate = round((total_panic_exits / qualification_sessions) * 100, 2) . \"%\"\n| eval avg_duration_seconds = round(avg_duration_seconds, 2)\n| eval avg_unique_cmds = round(avg_unique_cmds, 2)\n| table config_group, qualification_sessions, avg_unique_cmds, max_unique_cmds, avg_duration_seconds, median_duration_seconds, p90_duration_seconds, p95_duration_seconds, max_duration_seconds, panic_rate"
      },
      "name": "combined_iteration_time_data"
    },
    "ds_87uM98I1": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\" (eventid=\"cowrie.session.connect\" OR eventid=\"cowrie.command.input\" OR eventid=\"cowrie.session.closed\")\n| eval config_group = case(\n    match(sensor, \"combined\"), \"Combined\",\n    match(sensor, \"baseline\"), \"Baseline\"\n  )\n| eval local_ip = coalesce(dst_ip, dest_ip)\n| stats \n    count(eval(eventid=\"cowrie.command.input\")) as total_commands,\n    values(input) as all_commands,\n    dc(input) as distinct_session_cmds,\n    min(_time) as session_start,\n    max(_time) as session_end,\n    values(src_ip) as attacker_ip,\n    values(local_ip) as honeypot_ip\n    by config_group, session\n| eval session_duration = session_end - session_start\n| eval contains_uname = if(match(all_commands, \"uname\"), 1, 0)\n| eval panic_exit = if(match(all_commands, \"(exit|logout|history\\s+-c|kill\\s+-9)\"), 1, 0)\n| where total_commands > 2 AND contains_uname=1\n| stats \n    count as qualification_sessions,\n    dc(attacker_ip) as unique_attacker_ips,\n    avg(distinct_session_cmds) as avg_unique_cmds,\n    max(distinct_session_cmds) as max_unique_cmds,\n    avg(session_duration) as avg_duration_seconds,\n    max(session_duration) as max_duration_seconds,\n    median(session_duration) as median_duration_seconds,\n    perc90(session_duration) as p90_duration_seconds,\n    perc95(session_duration) as p95_duration_seconds,\n    sum(panic_exit) as total_panic_exits\n    by config_group, honeypot_ip\n| eval panic_rate = round((total_panic_exits / qualification_sessions) * 100, 2) . \"%\"\n| eval avg_duration_seconds = round(avg_duration_seconds, 2)\n| eval avg_unique_cmds = round(avg_unique_cmds, 2)\n| sort config_group, -qualification_sessions\n| table config_group, honeypot_ip, qualification_sessions, unique_attacker_ips, avg_unique_cmds, max_unique_cmds, avg_duration_seconds, median_duration_seconds, p90_duration_seconds, p95_duration_seconds, max_duration_seconds, panic_rate"
      },
      "name": "per ip combined config"
    }
  },
