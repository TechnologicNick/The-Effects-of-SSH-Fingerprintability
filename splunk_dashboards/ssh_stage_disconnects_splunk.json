  "dataSources": {
    "ds_c8bbySuw": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"\n| eval level=case(\n    eventid=\"cowrie.client.version\",1,\n    eventid=\"cowrie.client.kex\",2,\n    match(eventid,\"^cowrie\\.login\\.\"),3,\n    true(),0\n)\n| stats\n    max(level) as max_stage\n    first(sensor) as sensor\n    by session\n| eval banner=if(max_stage=1,1,0)\n| stats\n    count as total_sessions\n    sum(banner) as banner_sessions\n    by sensor\n| table sensor total_sessions banner_sessions",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "Total sessions and disconnects after banner search"
    },
    "ds_eSmtLfn7": {
      "type": "ds.search",
      "options": {
        "query": "index=\"cowrie\"\n| eval level=case(\n    eventid=\"cowrie.client.version\",1,\n    eventid=\"cowrie.client.kex\",2,\n    match(eventid,\"^cowrie\\.login\\.\"),3,\n    true(),0\n)\n| stats\n    max(level) as max_stage\n    first(sensor) as sensor\n    by session\n| eval kex=if(max_stage=2,1,0)\n| stats\n    count as total_sessions\n    sum(kex) as kex_sessions\n    by sensor\n| table sensor total_sessions kex_sessions",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now"
        }
      },
      "name": "Total sessions and disconnects after key exchange search"
    }
